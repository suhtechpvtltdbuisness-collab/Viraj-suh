# Environment Variables for Viraj Jewellers Website
# Copy this file to .env.local and fill in your actual values

# Google Analytics 4 Measurement ID
# Get this from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Google Search Console Verification Code
# Get this from: https://search.google.com/search-console
# Choose HTML tag method and paste the content value
NEXT_PUBLIC_GSC_VERIFICATION=your_google_verification_code_here

# Facebook Domain Verification (Optional)
# Get this from: Facebook Business Manager
NEXT_PUBLIC_FB_DOMAIN_VERIFICATION=your_facebook_verification_code

# Yandex Webmaster Verification (Optional)
# Get this from: https://webmaster.yandex.com
NEXT_PUBLIC_YANDEX_VERIFICATION=your_yandex_verification_code

# Yahoo Site Explorer (Optional)
NEXT_PUBLIC_YAHOO_VERIFICATION=your_yahoo_verification_code

# MongoDB Connection (for production data)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# API Keys (if needed)
GOLD_API_KEY=your_gold_api_key_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://virajjewellers.com
NEXT_PUBLIC_SITE_NAME=Viraj Jewellers
NEXT_PUBLIC_CONTACT_EMAIL=support@virajjewellers.com
NEXT_PUBLIC_CONTACT_PHONE=+919810100561

# Development Mode
NODE_ENV=production
